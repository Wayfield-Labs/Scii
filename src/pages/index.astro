---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
---

<Base title="WAYFIELD / Scii — Status">
  <div class="max-w-3xl mx-auto px-6">
    <Header>
      <div slot="right" id="overall" class="px-3 py-1 rounded-full text-sm bg-zinc-800 text-zinc-300">Checking...</div>
    </Header>

    <div class="mb-8">
      <h1 class="text-3xl font-sora font-semibold tracking-tight mb-2">System status</h1>
      <p class="text-zinc-500 font-inter">Uptime monitoring for WAYFIELD infrastructure, powered by Scii.</p>
    </div>

    <div id="services" class="space-y-3"></div>

    <h2 class="mt-12 mb-3 text-xs uppercase tracking-widest text-zinc-500 font-inter">Recent incidents</h2>
    <div id="incidents" class="space-y-2"></div>

    <footer class="mt-20 pb-10 text-xs text-zinc-600 font-inter">
      Updated <span id="updated">-</span> • <a href="/app" class="hover:text-zinc-400">Manage monitors</a>
    </footer>
  </div>

  <script>
    const STATUS_URL = 'https://scii-worker.your-subdomain.workers.dev/status.json';
    const ISSUES_URL = 'https://api.github.com/repos/user/scii-config/issues?state=all&labels=incident&per_page=10';

    async function load() {
      try {
        const [status, issues] = await Promise.all([
          fetch(STATUS_URL).then(r=>r.json()),
          fetch(ISSUES_URL).then(r=>r.json())
        ]);

        document.getElementById('updated').textContent = new Date(status.updated).toLocaleTimeString();

        const servicesEl = document.getElementById('services');
        servicesEl.innerHTML = status.services.map(s => {
          const host = new URL(s.url).hostname;
          const color = s.status==='up' ? 'bg-scii' : s.status==='down' ? 'bg-red-500' : 'bg-yellow-500';
          const border = s.status==='up' ? 'border-zinc-800' : 'border-red-900/50';
          return `
            <div class="bg-zinc-900/70 backdrop-blur border ${border} rounded-2xl p-5 flex items-center justify-between hover:bg-zinc-900 transition">
              <div>
                <div class="font-inter font-medium text-zinc-100">${host}</div>
                <div class="text-xs text-zinc-500 mt-0.5 font-mono">${s.url}</div>
              </div>
              <div class="flex items-center gap-4">
                <span class="text-sm text-zinc-400 font-inter">${s.latency}ms</span>
                <span class="w-2.5 h-2.5 rounded-full ${color} shadow-[0_0_8px_rgba(80,200,120,0.5)]"></span>
              </div>
            </div>
          `;
        }).join('');

        const allUp = status.services.every(s=>s.status==='up');
        const overall = document.getElementById('overall');
        overall.textContent = allUp ? 'All operational' : 'Partial outage';
        overall.className = 'px-3 py-1 rounded-full text-sm font-inter ' + (allUp ? 'bg-scii/20 text-scii' : 'bg-yellow-900/40 text-yellow-300');

        document.getElementById('incidents').innerHTML = issues.length ? issues.map(i => `
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-xl p-4">
            <div class="flex justify-between items-start gap-4">
              <div>
                <div class="font-inter ${i.state==='open'?'text-red-400':'text-zinc-300'}">${i.title}</div>
                <div class="text-xs text-zinc-500 mt-1">${new Date(i.created_at).toLocaleString()}</div>
              </div>
              <span class="text-[10px] uppercase tracking-wider px-2 py-1 rounded bg-zinc-800 text-zinc-400">${i.state}</span>
            </div>
          </div>
        `).join('') : '<div class="text-zinc-600 font-inter">No incidents in the last 30 days</div>';

      } catch(e) {
        console.error(e);
      }
    }
    load();
    setInterval(load, 60000);
  </script>
</Base>
